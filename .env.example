# Shopify Storefront API — copy this file to `.env` and fill in your local values.
#
# `.env` (and other real env files) are gitignored; never commit real values.
# The Storefront access token is public-by-design but still operationally
# sensitive: keep it out of version control, logs, and screenshots.

EXPO_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
EXPO_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-public-storefront-access-token
EXPO_PUBLIC_SHOPIFY_API_VERSION=2026-07
